# CORELINK Docker Build Exclusions
# Files and directories to exclude from Docker build context

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual Environments
venv/
env/
ENV/
.venv

# Environment Variables
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# Documentation
docs/
*.md
!README.md

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# Logs
*.log
logs/

# Database
*.db
*.sqlite
*.sqlite3

# Migrations (optional - uncomment if you don't want migrations in image)
# migrations/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Temporary files
tmp/
temp/
*.tmp
