# ── CoreLink Environment Configuration ─────────────────────────────────────
# Copy this file to .env and fill in your values.

# App
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/corelink

# Redis
REDIS_URL=redis://localhost:6379/0

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here
WEBHOOK_SECRET=your-webhook-secret-here

# ── AI Provider ─────────────────────────────────────────────────────────────
# CoreLink uses a cascading AI strategy:
#   1. If OPENAI_API_KEY is set → use OpenAI (GPT-4o-mini by default)
#   2. If not set              → use Ollama (local Llama3, no API key needed)
#
# To use Ollama (free, local):
#   1. Install: https://ollama.ai
#   2. Pull a model: ollama pull llama3
#   3. Leave OPENAI_API_KEY blank below
#
# To use OpenAI:
#   Set OPENAI_API_KEY to your key (starts with sk-)

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (only needed if you want to change the defaults)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Payment Providers ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
